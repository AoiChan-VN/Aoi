---
import "../styles/global.css";
---
<!DOCTYPE html>
<html lang="en" transition:animate="fade">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO -->
    <meta name="description" content="Astro 2026 ultra fast website" />
    <meta property="og:title" content="Astro 2026" />
    <meta property="og:type" content="website" />

    <!-- Prefetch -->
    <link rel="prefetch" href="/gallery" />
    <link rel="prefetch" href="/docs" />

    <title>Astro 2026</title>
  </head>

  <body>
    <!-- PURE CSS THEME ENGINE (ZERO JS) -->
    <input type="radio" name="theme" id="theme-light" hidden checked />
    <input type="radio" name="theme" id="theme-dark" hidden />
    <input type="radio" name="theme" id="theme-cyber" hidden />

    <slot />
  </body>
</html>
