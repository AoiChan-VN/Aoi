export class State {
    constructor() {
        this.data = {
            theme: localStorage.getItem('aoi_theme') || 'dark',
            bg: localStorage.getItem('aoi_bg') !== 'false',
            lang: localStorage.getItem('aoi_lang') || 'vi'
        };
    }
    update(k, v) { this.data[k] = v; localStorage.setItem(`aoi_${k}`, v); }
    get(k) { return this.data[k]; }
}
