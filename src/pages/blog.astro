---
import BaseLayout from "../layouts/BaseLayout.astro";
import blog from "../data/blog.json";
---

<BaseLayout>
  <h2>Blog</h2>

  {blog.map(post => (
    <div class="glass" style="padding:10px; margin:10px;">
      <h3>{post.title}</h3>
      <p>{post.content}</p>
    </div>
  ))}
</BaseLayout> 
